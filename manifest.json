<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Diabolik">
<meta name="theme-color" content="#cc0000">
<title>DIABOLIK — Archivio</title>
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@300;400;600;700&family=Special+Elite&display=swap" rel="stylesheet">

<style>
:root {
  --black: #0a0a0a;
  --deep: #111111;
  --red: #cc0000;
  --red-bright: #ff1a1a;
  --yellow: #f5c518;
  --white: #f0ece4;
  --gray: #888;
  --card-bg: #161616;
  --border: #2a2a2a;
  --nav-h: 64px;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}

* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

html, body {
  height: 100%;
  overflow: hidden;
  background: var(--black);
  color: var(--white);
  font-family: 'Oswald', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* NOISE */
body::before {
  content:'';
  position:fixed;
  inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events:none;
  z-index:9999;
  opacity:0.35;
}

/* HEADER */
.app-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 56px;
  background: var(--deep);
  border-bottom: 2px solid var(--red);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  padding-top: env(safe-area-inset-top, 0px);
  z-index: 100;
}

.header-logo {
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo-hex {
  width: 36px; height: 36px;
  background: var(--red);
  clip-path: polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Bebas Neue'; font-size: 18px; color: var(--black);
  animation: pulse 3s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.06)} }

.logo-name {
  font-family: 'Bebas Neue';
  font-size: 26px;
  letter-spacing: 4px;
  color: var(--white);
}
.logo-name span { color: var(--red); }

.header-stats {
  display: flex;
  align-items: center;
  gap: 12px;
}

.hstat {
  text-align: right;
}
.hstat-num {
  font-family: 'Bebas Neue';
  font-size: 20px;
  color: var(--red);
  line-height: 1;
}
.hstat-label {
  font-size: 9px;
  letter-spacing: 1px;
  color: var(--gray);
  text-transform: uppercase;
}

/* MAIN CONTENT */
.app-content {
  position: fixed;
  top: 56px;
  bottom: calc(var(--nav-h) + var(--safe-bottom));
  left: 0; right: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* BOTTOM NAV */
.bottom-nav {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: calc(var(--nav-h) + var(--safe-bottom));
  padding-bottom: var(--safe-bottom);
  background: var(--deep);
  border-top: 2px solid var(--border);
  display: flex;
  z-index: 100;
}

.nav-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  color: var(--gray);
  cursor: pointer;
  gap: 4px;
  transition: color 0.2s;
  padding: 8px 0;
  position: relative;
}

.nav-btn.active { color: var(--red); }

.nav-btn.active::after {
  content: '';
  position: absolute;
  top: 0; left: 20%; right: 20%;
  height: 2px;
  background: var(--red);
}

.nav-icon { font-size: 22px; line-height: 1; }
.nav-label { font-family: 'Oswald'; font-size: 10px; letter-spacing: 1px; text-transform: uppercase; }

/* SCANNER NAV BTN — special red pill */
.nav-btn.scanner-btn {
  color: var(--white);
}
.nav-btn.scanner-btn .nav-icon-wrap {
  width: 52px; height: 52px;
  background: var(--red);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px;
  margin-top: -20px;
  border: 3px solid var(--black);
  box-shadow: 0 4px 16px rgba(204,0,0,0.5);
}
.nav-btn.scanner-btn.active .nav-icon-wrap { background: var(--red-bright); }

/* SECTIONS */
.section {
  display: none;
  padding: 16px;
  padding-bottom: 16px;
  min-height: 100%;
  animation: fadeIn 0.25s ease;
}
.section.active { display: block; }
@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

.section-head {
  margin-bottom: 16px;
}
.section-title {
  font-family: 'Bebas Neue';
  font-size: 32px;
  letter-spacing: 3px;
  color: var(--white);
  line-height: 1;
}
.section-title span { color: var(--red); }
.section-sub {
  font-family: 'Special Elite';
  font-size: 11px;
  color: var(--gray);
  letter-spacing: 2px;
  margin-top: 2px;
}

/* PROGRESS */
.progress-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-left: 3px solid var(--red);
  padding: 14px 16px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.progress-pct-big {
  font-family: 'Bebas Neue';
  font-size: 48px;
  color: var(--red);
  line-height: 1;
  flex-shrink: 0;
}
.progress-right { flex: 1; }
.progress-label {
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--gray);
  text-transform: uppercase;
  margin-bottom: 8px;
}
.progress-bar { height: 4px; background: var(--border); overflow: hidden; }
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--red), var(--red-bright));
  transition: width 1s ease;
}
.progress-nums {
  display: flex;
  justify-content: space-between;
  margin-top: 6px;
  font-size: 11px;
  color: var(--gray);
}

/* SEARCH */
.search-wrap {
  display: flex;
  gap: 8px;
  margin-bottom: 14px;
}
.search-input {
  flex: 1;
  background: var(--card-bg);
  border: 1px solid var(--border);
  color: var(--white);
  font-family: 'Oswald';
  font-size: 15px;
  padding: 10px 14px;
  outline: none;
  border-radius: 0;
}
.search-input:focus { border-color: var(--red); }

.filter-scroll {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 4px;
  margin-bottom: 14px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.filter-scroll::-webkit-scrollbar { display: none; }

.chip {
  background: var(--card-bg);
  border: 1px solid var(--border);
  color: var(--gray);
  font-family: 'Oswald';
  font-size: 11px;
  letter-spacing: 1px;
  padding: 6px 14px;
  white-space: nowrap;
  cursor: pointer;
  text-transform: uppercase;
  flex-shrink: 0;
  transition: all 0.2s;
}
.chip.active, .chip:active { background: var(--red); border-color: var(--red); color: var(--white); }

/* COMICS GRID — 3 col on mobile */
.comics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

@media (min-width: 400px) { .comics-grid { grid-template-columns: repeat(4, 1fr); } }
@media (min-width: 600px) { .comics-grid { grid-template-columns: repeat(5, 1fr); } }

.comic-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: transform 0.15s;
  position: relative;
  overflow: hidden;
  border-radius: 2px;
}
.comic-card:active { transform: scale(0.95); border-color: var(--red); }

.comic-cover {
  width: 100%;
  aspect-ratio: 2/3;
  background: linear-gradient(135deg,#1a1a1a,#2a1a1a);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.comic-cover::before {
  content:'';
  position:absolute;
  inset:0;
  background:repeating-linear-gradient(45deg,transparent,transparent 4px,rgba(204,0,0,0.04) 4px,rgba(204,0,0,0.04) 5px);
}
.comic-cover img { width:100%; height:100%; object-fit:cover; position:absolute; inset:0; }
.cover-num { font-family:'Bebas Neue'; font-size:36px; color:var(--red); z-index:1; line-height:1; }
.cover-label { font-size:8px; letter-spacing:2px; color:var(--gray); z-index:1; margin-top:2px; }

.rare-badge {
  position:absolute; top:5px; right:5px;
  background:var(--yellow); color:var(--black);
  font-family:'Bebas Neue'; font-size:9px;
  padding:2px 5px; z-index:2; letter-spacing:1px;
}

.comic-info { padding:7px 8px; border-top:1px solid var(--border); }
.c-num { font-family:'Bebas Neue'; font-size:16px; color:var(--red); line-height:1; }
.c-cond { font-size:9px; letter-spacing:1px; margin-top:2px; font-weight:600; }

/* SCANNER SECTION */
.scanner-section { max-width: 500px; margin: 0 auto; }

.camera-btn {
  width: 100%;
  background: var(--card-bg);
  border: 2px dashed var(--red);
  color: var(--white);
  padding: 40px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  transition: background 0.2s;
  margin-bottom: 16px;
}
.camera-btn:active { background: rgba(204,0,0,0.1); }
.camera-icon { font-size: 56px; }
.camera-text { font-family:'Bebas Neue'; font-size:24px; letter-spacing:4px; color:var(--red); }
.camera-sub { font-size:12px; color:var(--gray); letter-spacing:2px; text-align:center; }

.file-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 16px;
}
.file-opt-btn {
  background: var(--card-bg);
  border: 1px solid var(--border);
  color: var(--gray);
  font-family: 'Oswald';
  font-size: 13px;
  letter-spacing: 1px;
  padding: 14px;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  text-transform: uppercase;
  transition: all 0.2s;
}
.file-opt-btn:active { border-color: var(--red); color: var(--red); }
.file-opt-icon { font-size: 28px; }

#cameraInput, #galleryInput { display: none; }

/* LOADING */
.scan-loading {
  display: none;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  padding: 48px 20px;
  background: var(--card-bg);
  border: 1px solid var(--border);
  margin-bottom: 16px;
}
.scan-loading.show { display: flex; }
.spinner {
  width: 48px; height: 48px;
  border: 3px solid var(--border);
  border-top-color: var(--red);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to{transform:rotate(360deg)} }
.loading-text { font-family:'Bebas Neue'; font-size:22px; letter-spacing:4px; color:var(--red); }
.loading-sub { font-size:12px; color:var(--gray); letter-spacing:2px; text-align:center; }

/* SCAN RESULT */
.scan-result-card {
  display: none;
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-top: 3px solid var(--red);
  margin-bottom: 16px;
  overflow: hidden;
}
.scan-result-card.show { display: block; }

.scan-result-header {
  display: flex;
  gap: 14px;
  padding: 14px;
  border-bottom: 1px solid var(--border);
}
.scan-thumb {
  width: 80px; height: 112px;
  object-fit: cover;
  border: 1px solid var(--border);
  flex-shrink: 0;
}
.scan-result-title {
  font-family: 'Bebas Neue';
  font-size: 20px;
  color: var(--red);
  letter-spacing: 2px;
  margin-bottom: 10px;
}

.scan-fields { padding: 14px; display: flex; flex-direction: column; gap: 10px; }

.sf-row { display: flex; align-items: center; gap: 10px; }
.sf-label {
  font-size: 10px; letter-spacing: 2px;
  color: var(--gray); text-transform: uppercase;
  width: 60px; flex-shrink: 0;
}
.sf-input {
  flex: 1;
  background: var(--deep);
  border: 1px solid var(--border);
  color: var(--white);
  font-family: 'Oswald'; font-size: 14px;
  padding: 8px 10px;
  outline: none;
}
.sf-input:focus { border-color: var(--red); }

/* CONDITION PICKER */
.cond-row {
  display: flex;
  gap: 6px;
  padding: 0 14px 14px;
}
.cond-btn {
  flex: 1;
  background: var(--deep);
  border: 1px solid var(--border);
  color: var(--gray);
  font-family: 'Oswald'; font-size: 12px;
  padding: 8px 4px;
  cursor: pointer;
  text-align: center;
  transition: all 0.15s;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.cond-btn.sel { background: var(--red); border-color: var(--red); color: var(--white); }

.scan-actions {
  display: flex;
  gap: 10px;
  padding: 0 14px 14px;
}

/* BUTTONS */
.btn {
  background: var(--red);
  border: none;
  color: var(--white);
  font-family: 'Oswald'; font-size: 13px;
  letter-spacing: 2px;
  padding: 12px 20px;
  cursor: pointer;
  text-transform: uppercase;
  flex: 1;
  transition: background 0.2s;
}
.btn:active { background: var(--red-bright); }
.btn-ghost {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--gray);
  font-family: 'Oswald'; font-size: 13px;
  letter-spacing: 2px;
  padding: 12px 20px;
  cursor: pointer;
  text-transform: uppercase;
  transition: all 0.2s;
}
.btn-ghost:active { border-color: var(--red); color: var(--red); }

/* ADD FORM */
.form-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-top: 3px solid var(--red);
  padding: 16px;
  margin-bottom: 16px;
}
.form-group { margin-bottom: 14px; }
.form-label {
  display: block;
  font-size: 10px; letter-spacing: 2px;
  color: var(--gray); text-transform: uppercase;
  margin-bottom: 5px;
}
.form-input {
  width: 100%;
  background: var(--deep);
  border: 1px solid var(--border);
  color: var(--white);
  font-family: 'Oswald'; font-size: 15px;
  padding: 10px 12px;
  outline: none;
}
.form-input:focus { border-color: var(--red); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

/* MANCANTI */
.sources-scroll {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  margin-bottom: 16px;
  padding-bottom: 4px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.sources-scroll::-webkit-scrollbar { display: none; }

.source-pill {
  background: var(--card-bg);
  border: 1px solid var(--border);
  padding: 10px 16px;
  flex-shrink: 0;
  text-align: center;
  min-width: 100px;
}
.source-pill-icon { font-size: 24px; display: block; margin-bottom: 4px; }
.source-pill-name { font-family:'Bebas Neue'; font-size: 14px; letter-spacing: 2px; color: var(--white); }

.missing-item {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-left: 3px solid var(--red);
  padding: 12px 14px;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 14px;
}
.m-num {
  font-family:'Bebas Neue'; font-size: 32px;
  color: var(--red); line-height: 1;
  min-width: 52px; text-align: center;
}
.m-info { flex: 1; overflow: hidden; }
.m-title { font-size: 13px; font-weight: 600; color: var(--white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.m-meta { font-size: 11px; color: var(--gray); margin-top: 2px; }
.m-right { text-align: right; flex-shrink: 0; }
.m-price {
  font-family:'Bebas Neue'; font-size: 20px;
  color: var(--yellow); line-height: 1;
}
.m-links { display: flex; flex-direction: column; gap: 3px; margin-top: 4px; }
.m-link {
  font-size: 10px; color: var(--gray);
  text-decoration: none; letter-spacing: 1px;
  display: flex; align-items: center; gap: 2px;
  justify-content: flex-end;
}
.m-link:active { color: var(--red); }

/* DETAIL SHEET */
.sheet-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 200;
  display: none;
}
.sheet-overlay.open { display: block; }

.bottom-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--deep);
  border-top: 3px solid var(--red);
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32,0.72,0,1);
  max-height: 85vh;
  overflow-y: auto;
  padding-bottom: env(safe-area-inset-bottom, 16px);
}
.bottom-sheet.open { transform: translateY(0); }

.sheet-handle {
  width: 36px; height: 4px;
  background: var(--border);
  border-radius: 2px;
  margin: 12px auto 8px;
}

.sheet-header {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 20px;
  border-bottom: 1px solid var(--border);
}
.sheet-cover {
  width: 70px; height: 100px;
  background: linear-gradient(135deg,#1a1a1a,#2a1a1a);
  display: flex; align-items: center; justify-content: center;
  flex-direction: column;
  font-family:'Bebas Neue'; flex-shrink: 0;
  overflow: hidden; position: relative;
  border: 1px solid var(--border);
}
.sheet-cover img { width:100%; height:100%; object-fit:cover; position:absolute; }
.sheet-cover-num { font-size: 32px; color: var(--red); z-index:1; }
.sheet-cover-lbl { font-size: 8px; letter-spacing: 2px; color: var(--gray); z-index:1; }

.sheet-title { font-family:'Bebas Neue'; font-size: 24px; color: var(--red); letter-spacing: 2px; line-height:1.1; }
.sheet-sub { font-size: 14px; color: var(--white); margin-top: 4px; }

.sheet-body { padding: 16px 20px; }
.sheet-meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
.sm-item label { font-size:9px; letter-spacing:2px; color:var(--gray); text-transform:uppercase; display:block; margin-bottom:2px; }
.sm-item span { font-size:14px; }

.sheet-notes {
  background: var(--card-bg);
  border: 1px solid var(--border);
  padding: 10px 12px;
  font-family:'Special Elite'; font-size:12px;
  color: var(--gray); line-height:1.6;
  margin-bottom: 16px;
}

.sheet-actions { display: flex; gap: 10px; }
.btn-danger {
  background: transparent;
  border: 1px solid #cc3333;
  color: #cc3333;
  font-family:'Oswald'; font-size:13px;
  letter-spacing:2px; padding:12px;
  cursor:pointer; text-transform:uppercase;
  flex: 1;
}
.btn-danger:active { background: rgba(204,0,0,0.1); }

/* TOAST */
.toast {
  position: fixed;
  top: 70px; left: 16px; right: 16px;
  background: var(--red);
  color: var(--white);
  font-family:'Oswald'; font-size:14px;
  letter-spacing:2px; padding:14px 16px;
  z-index:999;
  transform: translateY(-20px);
  opacity: 0;
  transition: all 0.3s;
  text-transform: uppercase;
  border-left: 4px solid var(--yellow);
  text-align: center;
}
.toast.show { transform: translateY(0); opacity: 1; }

/* EMPTY */
.empty-state {
  text-align:center; padding:60px 20px;
  color:var(--gray);
}
.empty-icon { font-size:56px; display:block; opacity:0.25; margin-bottom:12px; }
.empty-text { font-family:'Bebas Neue'; font-size:22px; letter-spacing:3px; color:var(--border); }
.empty-hint { font-size:12px; color:#555; margin-top:8px; }

/* INSTALL BANNER */
.install-banner {
  background: rgba(204,0,0,0.08);
  border: 1px solid rgba(204,0,0,0.3);
  border-left: 3px solid var(--red);
  padding: 12px 14px;
  margin-bottom: 16px;
  display: none;
}
.install-banner.show { display: flex; align-items: center; gap: 12px; }
.install-text { flex: 1; font-size: 13px; color: var(--white); }
.install-text strong { color: var(--red); font-family:'Bebas Neue'; letter-spacing:1px; font-size:15px; }
.install-btn {
  background: var(--red); border: none;
  color: var(--white); font-family:'Oswald';
  font-size:12px; letter-spacing:2px;
  padding: 8px 14px; cursor:pointer;
  text-transform:uppercase; flex-shrink:0;
}
</style>
</head>
<body>

<!-- HEADER -->
<header class="app-header">
  <div class="header-logo">
    <div class="logo-hex">D</div>
    <div class="logo-name">DIAB<span>O</span>LIK</div>
  </div>
