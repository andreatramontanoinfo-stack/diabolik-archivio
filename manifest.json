<script>
// ======== DATA ========
let collection = JSON.parse(localStorage.getItem('diabolikCollection') || '[]');
let addCond = 'NM', scanCond = 'NM', missingFilter = 'all', condFilter = '';
let currentSheetId = null;

const diabolikDB = {
  1:{title:"Il Re del Terrore",year:1962,price:450,rarity:"ultra-rare"},
  2:{title:"L'Asso di Picche",year:1962,price:380,rarity:"ultra-rare"},
  3:{title:"Il Lungo Addio",year:1962,price:320,rarity:"ultra-rare"},
  4:{title:"Il Castello della Paura",year:1963,price:280,rarity:"ultra-rare"},
  5:{title:"Senza Scampo",year:1963,price:85,rarity:"rare"},
  6:{title:"La Notte dello Scorpione",year:1963,price:80,rarity:"rare"},
  7:{title:"Il Tesoro di Kalonga",year:1963,price:75,rarity:"rare"},
  8:{title:"La Rivincita di Diabolik",year:1963,price:72,rarity:"rare"},
  9:{title:"La Morte Attende",year:1963,price:70,rarity:"rare"},
  10:{title:"Il Segreto di Diabolik",year:1963,price:75,rarity:"rare"},
  15:{title:"Le Mille Facce di Diabolik",year:1964,price:60,rarity:"rare"},
  20:{title:"Il Tesoro del Reno",year:1965,price:28,rarity:"medium"},
  25:{title:"La Notte del Serpente",year:1965,price:22,rarity:"medium"},
  30:{title:"La Morte può Attendere",year:1966,price:20,rarity:"medium"},
  42:{title:"Il Segno di Diabolik",year:1968,price:18,rarity:"medium"},
  50:{title:"Il Coltello Insanguinato",year:1969,price:15,rarity:"medium"},
  75:{title:"La Promessa Mantenuta",year:1972,price:8,rarity:"common"},
  100:{title:"Il Centenario",year:1975,price:18,rarity:"medium"},
  150:{title:"La Trappola d'Oro",year:1979,price:6,rarity:"common"},
  200:{title:"Il Doppio Tradimento",year:1983,price:5,rarity:"common"},
  250:{title:"La Maschera d'Argento",year:1987,price:4,rarity:"common"},
  300:{title:"Il Grande Colpo",year:1992,price:3,rarity:"common"},
  350:{title:"La Vendetta di Eva",year:1997,price:3,rarity:"common"},
  400:{title:"Il Tramonto di Diabolik",year:2001,price:4,rarity:"common"},
};

function getInfo(num) {
  return diabolikDB[num] || {
    title: "Episodio #"+num,
    year: num<100 ? 1962+Math.floor(num/5) : num<200 ? 1975+Math.floor((num-100)/12) : 1985+Math.floor((num-200)/14),
    rarity: num<5?"ultra-rare":num<20?"rare":num<100?"medium":"common",
    price: num<5?350:num<10?70:num<30?30:num<100?12:4
  };
}

function getPrice(num, cond) {
  const base = getInfo(num).price;
  const m = {NM:1,MB:0.7,B:0.5,M:0.3,D:0.15};
  return (base*(m[cond]||0.5)).toFixed(2);
}

function save() {
  localStorage.setItem('diabolikCollection', JSON.stringify(collection));
  updateStats();
}

// ======== NAV ========
function showSection(name, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById('sec-'+name).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  if (name==='archivio') renderArchivio();
  if (name==='mancanti') renderMancanti();
}

// ======== STATS ========
function updateStats() {
  const n = collection.length;
  const total = 900;
  const pct = Math.round(n/total*100);
  const val = collection.reduce((s,c) => s+parseFloat(getPrice(c.num,c.condition)),0);
  document.getElementById('hPosseduti').textContent = n;
  document.getElementById('hValore').textContent = '€'+Math.round(val);
  document.getElementById('progressPct').textContent = pct+'%';
  document.getElementById('progressFill').style.width = pct+'%';
  document.getElementById('pOwned').textContent = n+' posseduti';
  document.getElementById('pMissing').textContent = (total-n)+' mancanti';
}

// ======== ARCHIVIO ========
function setFilter(type, val, btn) {
  condFilter = val;
  document.querySelectorAll('.filter-scroll .chip').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderArchivio();
}

function renderArchivio() {
  const q = (document.getElementById('searchInput').value||'').toLowerCase();
  let items = collection.filter(c => {
    if (q && !String(c.num).includes(q) && !c.title.toLowerCase().includes(q)) return false;
    if (condFilter && c.condition !== condFilter) return false;
    return true;
  }).sort((a,b)=>a.num-b.num);

  const grid = document.getElementById('comicsGrid');
  if (!items.length) {
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1">
      <span class="empty-icon">📚</span>
      <div class="empty-text">ARCHIVIO VUOTO</div>
      <div class="empty-hint">Usa Scanner o Aggiungi per iniziare</div>
    </div>`;
    return;
  }

  const condColor = {NM:'#00cc66',MB:'#88cc00',B:'#f5c518',M:'#ff9900',D:'#cc0000'};
  grid.innerHTML = items.map(c => {
    const info = getInfo(c.num);
    const badge = info.rarity==='ultra-rare' ? '<div class="rare-badge">★★</div>' : info.rarity==='rare' ? '<div class="rare-badge">★</div>' : '';
    const img = c.coverData ? `<img src="${c.coverData}" alt="">` : '';
    const cc = condColor[c.condition]||'#888';
    return `<div class="comic-card" onclick="openSheet('${c.id}')">
      <div class="comic-cover">${img}${badge}
        <div class="cover-num" style="${c.coverData?'display:none':''}">${c.num}</div>
        <div class="cover-label" style="${c.coverData?'display:none':''}">DIABOLIK</div>
      </div>
      <div class="comic-info">
        <div class="c-num">#${c.num}</div>
        <div class="c-cond" style="color:${cc}">${c.condition}</div>
      </div>
    </div>`;
  }).join('');
}

// ======== BOTTOM SHEET ========
function openSheet(id) {
  const c = collection.find(x=>x.id===id);
  if (!c) return;
  currentSheetId = id;

  document.getElementById('sheetNum').textContent = `#${c.num} — ${c.series||'Prima Serie'}`;
  document.getElementById('sheetTitle').textContent = c.title;
  document.getElementById('sheetCoverNum').textContent = c.num;

  const ci = document.getElementById('sheetCover');
  if (c.coverData) {
    ci.innerHTML = `<img src="${c.coverData}">`;
  } else {
    ci.innerHTML = `<div class="sheet-cover-num">${c.num}</div><div class="sheet-cover-lbl">DIABOLIK</div>`;
  }

  const condColors = {NM:'#00cc66',MB:'#88cc00',B:'#f5c518',M:'#ff9900',D:'#cc0000'};
  const condLabels = {NM:'Near Mint',MB:'Molto Buono',B:'Buono',M:'Mediocre',D:'Danneggiato'};
  const rLabels = {'ultra-rare':'★★★ Ultra Raro','rare':'★★ Raro','medium':'★ Medio','common':'Comune'};
  const info = getInfo(c.num);

  document.getElementById('sheetMetaGrid').innerHTML = `
    <div class="sm-item"><label>Anno</label><span>${c.year}</span></div>
    <div class="sm-item"><label>Condizione</label><span style="color:${condColors[c.condition]}">${condLabels[c.condition]||c.condition}</span></div>
    <div class="sm-item"><label>Valore stimato</label><span style="color:var(--yellow)">€${getPrice(c.num,c.condition)}</span></div>
    <div class="sm-item"><label>Rarità</label><span>${rLabels[info.rarity]}</span></div>
    <div class="sm-item"><label>Aggiunto</label><span>${new Date(c.added).toLocaleDateString('it-IT')}</span></div>
    <div class="sm-item"><label>Serie</label><span>${c.series||'Prima Serie'}</span></div>
  `;

  const notesEl = document.getElementById('sheetNotes');
  if (c.notes) { notesEl.style.display='block'; notesEl.textContent='📝 '+c.notes; }
  else notesEl.style.display='none';

  document.getElementById('sheetOverlay').classList.add('open');
  setTimeout(()=>document.getElementById('bottomSheet').classList.add('open'),10);
}

function closeSheet() {
  document.getElementById('bottomSheet').classList.remove('open');
  document.getElementById('sheetOverlay').classList.remove('open');
  currentSheetId = null;
}

function deleteFromSheet() {
  if (!currentSheetId) return;
  const c = collection.find(x=>x.id===currentSheetId);
  if (!confirm(`Rimuovere #${c?.num} dall'archivio?`)) return;
  collection = collection.filter(x=>x.id!==currentSheetId);
  save();
  closeSheet();
  renderArchivio();
  toast(`#${c?.num} rimosso dall'archivio`);
}

// ======== SCANNER ========
function handleScan(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = async (ev) => {
    const dataUrl = ev.target.result;
    document.getElementById('scanThumb').src = dataUrl;
    document.getElementById('scanLoading').classList.add('show');
    document.getElementById('scanResultCard').classList.remove('show');

    if (!getApiKey()) {
      document.getElementById('scanLoading').classList.remove('show');
      window._pendingCover = dataUrl;
      document.getElementById('scanThumb').src = dataUrl;
      toast('⚠️ Chiave API mancante — vai in Impostazioni');
      showSection('impostazioni', null);
      return;
    }

    try {
      const b64 = dataUrl.split(',')[1];
      const resp = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{
          "Content-Type":"application/json",
          "x-api-key": getApiKey(),
          "anthropic-version": "2023-06-01",
          "anthropic-dangerous-direct-browser-access": "true"
        },
        body: JSON.stringify({
          model:"claude-sonnet-4-20250514",
          max_tokens:400,
          messages:[{
            role:"user",
            content:[
              {type:"image",source:{type:"base64",media_type:file.type,data:b64}},
              {type:"text",text:`Questa è una copertina del fumetto italiano Diabolik. Analizza e rispondi SOLO con JSON:
{"numero":<intero o null>,"titolo":"<stringa>","anno":<intero o null>,"serie":"<stringa>"}
Solo JSON, nessun testo aggiuntivo.`}
            ]
          }]
        })
      });
      const data = await resp.json();
      let result = {numero:null,titolo:'',anno:null,serie:'Prima Serie'};
      try { result = JSON.parse(data.content[0].text.trim().replace(/```json|```/g,'')); } catch(e){}

      document.getElementById('scanLoading').classList.remove('show');
      document.getElementById('scanResultCard').classList.add('show');

      const info = result.numero ? getInfo(result.numero) : {};
      document.getElementById('scanNum').value = result.numero||'';
      document.getElementById('scanTitle').value = result.titolo||info.title||'';
      document.getElementById('scanYear').value = result.anno||info.year||'';
      document.getElementById('scanSeries').value = result.serie||'Prima Serie';
      window._pendingCover = dataUrl;

    } catch(err) {
      document.getElementById('scanLoading').classList.remove('show');
      document.getElementById('scanResultCard').classList.add('show');
      window._pendingCover = dataUrl;
      toast('Analisi completata — verifica i dati');
    }
  };
  reader.readAsDataURL(file);
}

function setScanCond(btn, val) {
  scanCond = val;
  document.querySelectorAll('#scanResultCard .cond-btn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
}

function confirmScanAdd() {
  const num = parseInt(document.getElementById('scanNum').value);
  const year = parseInt(document.getElementById('scanYear').value);
  if (!num||num<1) { toast('Inserisci un numero valido'); return; }
  if (!year||year<1962) { toast('Anno non valido (dal 1962)'); return; }
  const title = document.getElementById('scanTitle').value || getInfo(num).title;
  const series = document.getElementById('scanSeries').value || 'Prima Serie';
  if (collection.find(c=>c.num===num&&c.series===series)) { toast('Numero già in archivio!'); return; }
  collection.push({
    id: Date.now().toString(),
    num, year, title, series,
    condition: scanCond,
    notes: document.getElementById('scanNotes').value,
    coverData: window._pendingCover,
    added: Date.now()
  });
  save();
  resetScanner();
  toast(`#${num} aggiunto all'archivio! 🗡️`);
  showSection('archivio', document.querySelector('.nav-btn'));
  renderArchivio();
}

function resetScanner() {
  document.getElementById('scanLoading').classList.remove('show');
  document.getElementById('scanResultCard').classList.remove('show');
  document.getElementById('cameraInput').value = '';
  document.getElementById('galleryInput').value = '';
  window._pendingCover = null;
}

// ======== ADD ========
function setAddCond(btn, val) {
  addCond = val;
  document.querySelectorAll('#sec-aggiungi .cond-btn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
}

function addComic() {
  const num = parseInt(document.getElementById('addNum').value);
  const year = parseInt(document.getElementById('addYear').value);
  if (!num||num<1) { toast('Inserisci un numero valido'); return; }
  if (!year||year<1962) { toast('Anno non valido (dal 1962)'); return; }
  const info = getInfo(num);
  const title = document.getElementById('addTitle').value || info.title;
  const series = document.getElementById('addSeries').value;
  if (collection.find(c=>c.num===num&&c.series===series)) { toast('Numero già in archivio!'); return; }
  collection.push({
    id: Date.now().toString(),
    num, year, title, series,
    condition: addCond,
    notes: document.getElementById('addNotes').value,
    added: Date.now()
  });
  save();
  clearAdd();
  toast(`#${num} aggiunto! 🗡️`);
  showSection('archivio', document.querySelectorAll('.nav-btn')[0]);
  renderArchivio();
}

function clearAdd() {
  ['addNum','addTitle','addYear','addNotes'].forEach(id=>document.getElementById(id).value='');
  addCond='NM';
  document.querySelectorAll('#sec-aggiungi .cond-btn').forEach((b,i)=>b.classList.toggle('sel',i===0));
}

// ======== MANCANTI ========
function setMissingFilter(f, btn) {
  missingFilter = f;
  document.querySelectorAll('#missingFilterScroll .chip').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderMancanti();
}

function renderMancanti() {
  const owned = new Set(collection.map(c=>c.num));
  const knownNums = Object.keys(diabolikDB).map(Number);
  const first50 = Array.from({length:50},(_,i)=>i+1);
  const allNums = [...new Set([...knownNums,...first50])].filter(n=>!owned.has(n)).sort((a,b)=>a-b);

  const filtered = allNums.filter(n => {
    const {price} = getInfo(n);
    if (missingFilter==='rare') return price>15;
    if (missingFilter==='medium') return price>=5&&price<=15;
    if (missingFilter==='common') return price<5;
    return true;
  });

  if (!filtered.length) {
    document.getElementById('missingList').innerHTML = `<div class="empty-state"><span class="empty-icon">🎉</span><div class="empty-text">NESSUNO IN QUESTA FASCIA</div></div>`;
    return;
  }

  const rarityLabel = {'ultra-rare':'🔴 Ultra Raro','rare':'🔴 Raro','medium':'🟡 Medio','common':'🟢 Comune'};

  document.getElementById('missingList').innerHTML = filtered.slice(0,100).map(n => {
    const {title,year,price,rarity} = getInfo(n);
    const rl = rarityLabel[rarity];
    const links = [
      {name:'eBay',url:`https://www.ebay.it/sch/i.html?_nkw=diabolik+n+${n}`},
      {name:'Subito',url:`https://www.subito.it/annunci-italia/vendita/fumetti/?q=diabolik+${n}`},
      rarity!=='common'?{name:'Delcampe',url:`https://www.delcampe.net/it/collezioni/?q=diabolik+${n}`}:null
    ].filter(Boolean);

    return `<div class="missing-item">
      <div class="m-num">#${n}</div>
      <div class="m-info">
        <div class="m-title">${title}</div>
        <div class="m-meta">${year} · ${rl}</div>
      </div>
      <div class="m-right">
        <div class="m-price">~€${price}</div>
        <div class="m-links">
          ${links.map(l=>`<a class="m-link" href="${l.url}" target="_blank">↗ ${l.name}</a>`).join('')}
        </div>
      </div>
    </div>`;
  }).join('');
}



function exportData() {
  const json = JSON.stringify(collection, null, 2);
  const blob = new Blob([json], {type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href=url; a.download='diabolik-backup.json'; a.click();
  URL.revokeObjectURL(url);
  toast('Backup esportato!');
}

function importData(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    try {
      const data = JSON.parse(ev.target.result);
      if (!Array.isArray(data)) throw new Error();
      if (!confirm(`Importare ${data.length} fumetti? Questo sostituirà l'archivio attuale.`)) return;
      collection = data;
      save();
      renderArchivio();
      toast(`${data.length} fumetti importati!`);
    } catch(e) { toast('File non valido'); }
  };
  reader.readAsText(file);
}

// ======== TOAST ========
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2800);
}

// ======== PWA INSTALL ========
let deferredPrompt;
window.addEventListener('beforeinstallprompt', (e) => {
  e.preventDefault();
  deferredPrompt = e;
  document.getElementById('installBanner').classList.add('show');
});
document.getElementById('installBtn').addEventListener('click', async () => {
  if (!deferredPrompt) return;
  deferredPrompt.prompt();
  const {outcome} = await deferredPrompt.userChoice;
  if (outcome==='accepted') {
    document.getElementById('installBanner').classList.remove('show');
    toast('App installata! 🗡️');
  }
  deferredPrompt = null;
});
window.addEventListener('appinstalled', ()=>{
  document.getElementById('installBanner').classList.remove('show');
});

function updateApiKeyStatus() {
  const el = document.getElementById('scannerStatusBox');
  const bi = document.getElementById('backupInfo');
  if (bi) bi.textContent = collection.length + ' fumetti in archivio';
  if (!el) return;
  if (getApiKey()) {
    el.innerHTML = `<div style="font-family:'Bebas Neue';font-size:20px;letter-spacing:2px;color:#00cc66;">✓ SCANNER ATTIVO</div><div style="font-size:12px;color:var(--gray);letter-spacing:1px;margin-top:2px;">Riconoscimento copertine pronto</div>`;
  } else {
    el.innerHTML = `<div style="font-family:'Bebas Neue';font-size:20px;letter-spacing:2px;color:var(--red);">⚠ SCANNER NON ATTIVO</div><div style="font-size:12px;color:var(--gray);letter-spacing:1px;margin-top:2px;">Inserisci la chiave API per attivarlo</div>`;
  }
}

function changeKey() {
  const key = document.getElementById('changeKeyInput').value.trim();
  if (!key.startsWith('sk-ant-')) { toast('Chiave non valida'); return; }
  saveApiKey(key);
  document.getElementById('changeKeyInput').value = '';
  document.getElementById('changeKeyWrap').style.display = 'none';
  updateApiKeyStatus();
  toast('✓ Chiave aggiornata!');
}


function checkFirstLaunch() {
  if (!getApiKey()) {
    document.getElementById('setupScreen').style.display = 'block';
  }
}

function activateApp() {
  const key = document.getElementById('setupKeyInput').value.trim();
  const errEl = document.getElementById('setupError');
  if (!key) { errEl.style.display='block'; errEl.textContent='Inserisci la chiave API'; return; }
  if (!key.startsWith('sk-ant-')) { errEl.style.display='block'; errEl.textContent='Chiave non valida — deve iniziare con sk-ant-'; return; }
  saveApiKey(key);
  document.getElementById('setupScreen').style.display = 'none';
  toast('✓ App attivata! Benvenuto 🗡️');
}




// ======== API KEY ========
function getApiKey() { return localStorage.getItem('diabolik_api_key') || ''; }
function saveApiKey(key) { localStorage.setItem('diabolik_api_key', key.trim()); }


if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('./sw.js').catch(()=>{});
}

// ======== INIT ========
updateStats();
renderArchivio();
checkFirstLaunch();

// Demo data
if (!collection.length) {
  const demos = [
    {num:1,year:1962,title:'Il Re del Terrore',series:'Prima Serie',condition:'M',notes:'Prima edizione storica'},
    {num:10,year:1963,title:'Il Segreto di Diabolik',series:'Prima Serie',condition:'MB',notes:''},
    {num:42,year:1968,title:'Il Segno di Diabolik',series:'Prima Serie',condition:'NM',notes:'Trovato a Lucca Comics'},
    {num:100,year:1975,title:'Il Centenario',series:'Prima Serie',condition:'B',notes:''},
    {num:200,year:1983,title:'Il Doppio Tradimento',series:'Seconda Serie',condition:'MB',notes:''},
  ];
  demos.forEach(d=>collection.push({id:Date.now().toString()+Math.random(),added:Date.now(),...d}));
  save();
  renderArchivio();
}
</script>
</body>
